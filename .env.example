# Google Apps Script web app URLs for form submissions.
# See the setup instructions below to get these URLs.
#
# 1. Create a Google Sheet for waitlist emails
# 2. Go to Extensions > Apps Script
# 3. Paste the waitlist script (see SETUP section in README or repo docs)
# 4. Deploy as web app (Execute as: Me, Who has access: Anyone)
# 5. Copy the URL here
GOOGLE_SHEETS_WAITLIST_URL=https://script.google.com/macros/s/YOUR_WAITLIST_SCRIPT_ID/exec

# Same steps for a separate Applications sheet
GOOGLE_SHEETS_APPLICATIONS_URL=https://script.google.com/macros/s/YOUR_APPLICATIONS_SCRIPT_ID/exec
