# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────────────────────
# From Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Supabase ──────────────────────────────────────────────────────────────────
# From Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (transactional emails) ─────────────────────────────────────────────
# From https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Stripe (payments) ─────────────────────────────────────────────────────────
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── Daily.co (video calls) ────────────────────────────────────────────────
# From https://dashboard.daily.co/developers
DAILY_API_KEY=your-daily-api-key
DAILY_DOMAIN=your-daily-domain

# ── Google Sheets (waitlist & applications) ───────────────────────────────────
GOOGLE_SHEETS_WAITLIST_URL=https://script.google.com/macros/s/YOUR_WAITLIST_SCRIPT_ID/exec
GOOGLE_SHEETS_APPLICATIONS_URL=https://script.google.com/macros/s/YOUR_APPLICATIONS_SCRIPT_ID/exec
